        errorMsg.Font = Enum.Font.GothamBold
        errorMsg.TextSize = 16
        errorMsg.Text = "Error! Try again."
        errorMsg.TextTransparency = 1
        errorMsg.Parent = playerGui
        
        local errorCorner = Instance.new("UICorner")
        errorCorner.CornerRadius = UDim.new(0, 12)
        errorCorner.Parent = errorMsg
        
        TweenService:Create(errorMsg, TweenInfo.new(0.3), {
            BackgroundTransparency = 0.1,
            TextTransparency = 0
        }):Play()
        
        task.wait(2)
        
        TweenService:Create(errorMsg, TweenInfo.new(0.3), {
            BackgroundTransparency = 1,
            TextTransparency = 1
        }):Play()
        task.wait(0.3)
        errorMsg:Destroy()
    end
