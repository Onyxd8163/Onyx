    task.wait(1)
    
    TweenService:Create(statusMessage, TweenInfo.new(0.3), {
        BackgroundTransparency = 1,
        TextTransparency = 1
    }):Play()
    task.wait(0.3)
    statusMessage:Destroy()
    
