    local function loadInfYield()
        if infYieldLoaded then return end
        infYieldLoaded = true
        infYieldButton.Text = "Loading..."
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"))()
        end)
        if success then
            infYieldButton.Text = "Infinite Yield Loaded"
            TweenService:Create(infYieldButton, TweenInfo.new(0.4), {
                BackgroundColor3 = Color3.fromRGB(0, 150, 80)
            }):Play()
        else
            infYieldButton.Text = "Error! Try Again"
            infYieldLoaded = false
        end
        task.wait(2)
        infYieldButton.Text = "Infinite Yield"
        TweenService:Create(infYieldButton, TweenInfo.new(0.4), {
            BackgroundColor3 = Color3.fromRGB(90, 30, 240)
        }):Play()
    end

    local function switchPage(pageNum)
        if currentPage == pageNum then return end
        
        local oldPage = currentPage
        currentPage = pageNum
        
        local pages = {page1Frame, page2Frame, page3Frame, page4Frame}
        local direction = (pageNum > oldPage) and 1 or -1
        
        local oldFrame = pages[oldPage]
        if oldFrame then
            TweenService:Create(oldFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(direction * -1, 0, 0, 0)
            }):Play()
            
            task.wait(0.15)
            oldFrame.Visible = false
            oldFrame.Position = UDim2.new(0, 0, 0, 0)
        end
        
        local newFrame = pages[pageNum]
        newFrame.Position = UDim2.new(direction * 1, 0, 0, 0)
        newFrame.Visible = true
        
        TweenService:Create(newFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()
        
        if pageNum == 2 then
            updatePlayerList(searchBox.Text)
        end
        
        local function animateButton(button, isActive)
            TweenService:Create(button, TweenInfo.new(0.3), {
                BackgroundColor3 = isActive and Color3.fromRGB(0, 100, 220) or Color3.fromRGB(22, 22, 30),
                TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(190, 190, 190)
            }):Play()
            button.Font = isActive and Enum.Font.GothamBlack or Enum.Font.Gotham
        end
        
        animateButton(page1Button, pageNum == 1)
        animateButton(page2Button, pageNum == 2)
        animateButton(page3Button, pageNum == 3)
        animateButton(page4Button, pageNum == 4)
    end

