    local function updatePlayerList(searchTerm)
        local players = Players:GetPlayers()
        
        -- Clear and rebuild
        local existingButtons = {}
        for _, child in ipairs(playerListFrame:GetChildren()) do
            if child:IsA("TextButton") then
                existingButtons[child.Name] = child
            end
        end
        
        -- Remove buttons for players that left
        for name, btn in pairs(existingButtons) do
            local found = false
            for _, plr in ipairs(players) do
                if plr.Name == name then
                    found = true
                    break
                end
            end
            if not found then
                btn:Destroy()
            end
        end
        
        -- Add/update buttons
        for _, plr in ipairs(players) do
            if not searchTerm or string.find(string.lower(plr.Name), string.lower(searchTerm)) then
                local playerButton = existingButtons[plr.Name]
                
                if not playerButton then
                    playerButton = Instance.new("TextButton")
                    playerButton.Name = plr.Name
                    playerButton.Size = UDim2.new(1, -10, 0, 30)
                    playerButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                    playerButton.Font = Enum.Font.Gotham
                    playerButton.TextSize = 13
                    playerButton.Parent = playerListFrame
                    
                    local btnCorner = Instance.new("UICorner")
                    btnCorner.CornerRadius = UDim.new(0, 8)
                    btnCorner.Parent = playerButton
                    
                    local btnStroke = Instance.new("UIStroke")
                    btnStroke.Color = Color3.fromRGB(0, 0, 0)
                    btnStroke.Transparency = 0.5
                    btnStroke.Thickness = 1
                    btnStroke.Parent = playerButton
                    
                    if plr ~= player then
                        playerButton.MouseButton1Click:Connect(function()
                            selectedPlayer = plr
                            updatePlayerList(searchBox.Text)
                        end)
                    end
                end
                
                playerButton.BackgroundColor3 = (plr == player) and Color3.fromRGB(50, 50, 60) or 
                                              (plr == selectedPlayer) and Color3.fromRGB(0, 120, 255) or 
                                              Color3.fromRGB(28, 28, 36)
                playerButton.Text = plr.Name .. (plr == player and " (You)" or "")
                playerButton.Visible = true
            else
                if existingButtons[plr.Name] then
                    existingButtons[plr.Name].Visible = false
                end
            end
        end
    end

    local function teleportToPlayer()
        if not selectedPlayer or not selectedPlayer.Character then 
            return
        end
        if not player.Character then return end
        
        local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
        local targetRoot = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if not rootPart or not targetRoot then return end
        
        local distance = (rootPart.Position - targetRoot.Position).Magnitude
        local duration = math.min(distance / 150, 2)
        
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetRoot.CFrame})
        tween:Play()
    end

