local function createESP(plr)
    if plr == player then return end
    
    local function updateESP()
        if not espEnabled then
            if espObjects[plr] then
                espObjects[plr]:Destroy()
                espObjects[plr] = nil
            end
            return
        end
        
        if not plr.Character then
            if espObjects[plr] then
                espObjects[plr]:Destroy()
                espObjects[plr] = nil
            end
            return
        end
        
        local humanoidRootPart = plr.Character:FindFirstChild("HumanoidRootPart")
        local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
        
        if not humanoidRootPart or not humanoid or humanoid.Health <= 0 then
            if espObjects[plr] then
                espObjects[plr]:Destroy()
                espObjects[plr] = nil
            end
            return
        end
        
        if not espObjects[plr] then
            local billboard = Instance.new("BillboardGui")
            billboard.Name = plr.Name .. "ESP"
            billboard.Adornee = humanoidRootPart
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            billboard.AlwaysOnTop = true
            billboard.MaxDistance = 1000
            billboard.Parent = playerGui
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = plr.Name
            textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            textLabel.TextStrokeTransparency = 0
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextSize = 14
            textLabel.Parent = billboard
            
            local hpBar = Instance.new("Frame")
            hpBar.Name = "HPBar"
            hpBar.Size = UDim2.new(1, 0, 0.2, 0)
            hpBar.Position = UDim2.new(0, 0, 1, 0)
            hpBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            hpBar.BorderSizePixel = 0
            hpBar.Parent = billboard
            
            espObjects[plr] = billboard
        end
        
        local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
        if humanoid and espObjects[plr]:FindFirstChild("HPBar") then
            local hpPercent = humanoid.Health / humanoid.MaxHealth
            espObjects[plr].HPBar.Size = UDim2.new(hpPercent, 0, 0.2, 0)
            if hpPercent > 0.5 then
                espObjects[plr].HPBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            elseif hpPercent > 0.25 then
                espObjects[plr].HPBar.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
            else
                espObjects[plr].HPBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
    end
    
    local conn
    if espEnabled then
        conn = RunService.Heartbeat:Connect(updateESP)
    end
    espConnections[plr] = conn
end

local function removeESP(plr)
    if espConnections[plr] then
        espConnections[plr]:Disconnect()
        espConnections[plr] = nil
    end
    if espObjects[plr] then
        espObjects[plr]:Destroy()
        espObjects[plr] = nil
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    
    if espEnabled then
        for _, plr in ipairs(Players:GetPlayers()) do
            createESP(plr)
        end
        
        espConnections.playerAdded = Players.PlayerAdded:Connect(function(plr)
            createESP(plr)
        end)
        
        espConnections.playerRemoving = Players.PlayerRemoving:Connect(function(plr)
            removeESP(plr)
        end)
        
        for _, plr in ipairs(Players:GetPlayers()) do
            plr.CharacterAdded:Connect(function()
                task.wait(0.5)
                if espEnabled and plr ~= player then
                    if espObjects[plr] then
                        espObjects[plr]:Destroy()
                        espObjects[plr] = nil
                    end
                    createESP(plr)
                end
            end)
        end
    else
        for plr, _ in pairs(espObjects) do
            removeESP(plr)
        end
        
        if espConnections.playerAdded then
            espConnections.playerAdded:Disconnect()
            espConnections.playerAdded = nil
        end
        if espConnections.playerRemoving then
            espConnections.playerRemoving:Disconnect()
            espConnections.playerRemoving = nil
        end
    end
end

